{
  "serverAddr": "your-server.com",
  "serverPort": 7000,
  "token": "your-auth-token",
  "protocol": "tcp",
  "tlsEnable": true,
  "tlsCertPath": "",
  "tlsCertPassword": "",
  "poolCount": 5,
  "tcpMux": true,
  "heartbeatInterval": 30,
  "heartbeatTimeout": 90,
  "tunnels": [
    {
      "localPort": 8080,
      "remotePort": 8080,
      "protocol": "tcp",
      "useEncryption": true,
      "useCompression": false,
      "bandwidthLimit": 1024,
      "healthCheckPath": "/health",
      "healthCheckInterval": 10,
      "loadBalanceStrategy": "round_robin",
      "backends": [
        {
          "address": "127.0.0.1",
          "port": 8080,
          "weight": 1
        },
        {
          "address": "127.0.0.1",
          "port": 8081,
          "weight": 1
        }
      ]
    },
    {
      "localPort": 3306,
      "remotePort": 3306,
      "protocol": "tcp",
      "useEncryption": true,
      "bandwidthLimit": 2048
    },
    {
      "localPort": 5432,
      "remotePort": 5432,
      "protocol": "tcp",
      "useEncryption": false,
      "bandwidthLimit": 0
    }
  ]
}